# ===== Cấu hình máy chủ =====
# development | production
NODE_ENV=development
PORT=3000

# ===== Cấu hình MySQL (mặc định của XAMPP) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=danhcotuong

# ===== Phiên đăng nhập =====
# Sinh chuỗi ngẫu nhiên: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=doi-chuoi-bi-mat-nay-thanh-ngau-nhien

# Bật cookie secure (chỉ gửi cookie qua HTTPS). 'true' khi chạy sau Nginx + HTTPS.
# Khi NODE_ENV=production mặc định đã bật; đặt 'false' nếu cần test production qua HTTP thuần.
COOKIE_SECURE=false
