# nginx.conf.example — Reverse proxy + HTTPS cho Đánh Cờ Tướng Online (Node trên cổng 3000)
#
# Cài: copy vào /etc/nginx/sites-available/danhcotuong, sửa server_name,
#   sudo ln -s /etc/nginx/sites-available/danhcotuong /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
# HTTPS miễn phí: sudo certbot --nginx -d danhcotuong.online -d www.danhcotuong.online

# Chuyển HTTP -> HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name danhcotuong.online www.danhcotuong.online;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name danhcotuong.online www.danhcotuong.online;

    # Certbot tự điền 2 dòng dưới khi chạy. Để sẵn placeholder:
    ssl_certificate     /etc/letsencrypt/live/danhcotuong.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/danhcotuong.online/privkey.pem;

    # Cho phép body lớn vừa phải (khớp limit 1mb của Express)
    client_max_body_size 1m;

    # API + trang tĩnh -> Node
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # WebSocket (đấu online — Giai đoạn 2)
    location /ws {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host       $host;
        proxy_read_timeout 86400;
    }
}
